{
  "cli": {
    "version": ">= 16.24.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.eatquicker.fr",
        "EXPO_PUBLIC_WS_URL": "wss://ws.eatquicker.fr",
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_PROJECT_ID": "aec49fe2-48a9-417e-9552-31fc13700804"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
{
  "expo": {
    "name": "EatQuickeR",
    "slug": "EatQuickeR",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.fingerliing.EatQuickeR",
      "associatedDomains": [
        "applinks:api.eatquicker.fr",
        "applinks:eatquicker.fr"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "fr.fingerliing.EatQuickeR",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.eatquicker.fr",
              "pathPrefix": "/t/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1E3A5F",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.fr.fingerliing.EatQuickeR",
          "enableGooglePay": true
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.eatquicker.fr",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aec49fe2-48a9-417e-9552-31fc13700804"
      }
    },
    "scheme": "eatquicker",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aec49fe2-48a9-417e-9552-31fc13700804"
    }
  }
}
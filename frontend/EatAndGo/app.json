{
  "expo": {
    "name": "EatQuickeR",
    "slug": "EatQuickeR",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.fingerliing.EatQuickeR",
      "associatedDomains": [
        "applinks:api.eatquicker.fr",
        "applinks:eatquicker.fr"
      ],
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "EatQuickeR utilise l'appareil photo pour scanner les QR codes de table et accéder au menu du restaurant.",
        "NSPhotoLibraryUsageDescription": "EatQuickeR a besoin d'accéder à vos photos pour personnaliser votre profil ou ajouter une image à un plat (restaurateurs uniquement).",
        "NSPhotoLibraryAddUsageDescription": "EatQuickeR peut enregistrer le QR code de votre session dans votre galerie pour faciliter le partage."
      }
    },
    "android": {
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0C1219"
      },
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "edgeToEdgeEnabled": true,
      "package": "fr.fingerliing.EatQuickeR",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.eatquicker.fr",
              "pathPrefix": "/t/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Autorisez $(PRODUCT_NAME) à utiliser Face ID pour vous reconnecter." }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1E3A5F",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.fr.fingerliing.EatQuickeR",
          "enableGooglePay": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.161444086922-0e30dfkvqiba6o9vhce8ap5432ptkqrt"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "EatQuickeR utilise l'appareil photo pour scanner les QR codes de table.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EatQuickeR a besoin d'accéder à vos photos pour personnaliser votre profil ou ajouter une image à un plat.",
          "cameraPermission": "EatQuickeR utilise l'appareil photo pour prendre une photo de profil ou d'un plat."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.eatquicker.fr",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aec49fe2-48a9-417e-9552-31fc13700804"
      }
    },
    "scheme": "eatquicker",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aec49fe2-48a9-417e-9552-31fc13700804"
    }
  }
}